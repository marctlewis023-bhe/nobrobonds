---
const learnLinks = [
  { href: "/how-it-works", label: "How It Works" },
  { href: "/bond-types", label: "Bond Types" },
  { href: "/the-broker-problem", label: "The Broker Problem" },
  { href: "/resources/glossary", label: "Glossary" },
];

const resourceLinks = [
  { href: "/resources", label: "All Resources" },
  { href: "/blog", label: "Blog" },
  { href: "/about", label: "About" },
];

const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border mt-24">
  <div class="max-w-[1280px] mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      {/* Logo + disclaimer */}
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2.5 no-underline mb-4">
          <span
            class="w-9 h-9 rounded-[10px] bg-accent flex items-center justify-center text-white font-display font-bold text-sm"
          >
            NB
          </span>
          <span class="font-display font-bold text-primary text-lg">NoBro Bonds</span>
        </a>
        <p class="text-muted text-sm leading-relaxed max-w-md">
          NoBro Bonds is an informational platform designed to help contractors,
          business owners, and professionals understand surety bonds without the
          broker runaround. We don't sell bonds — we help you understand them.
        </p>
      </div>

      {/* Learn column */}
      <div>
        <h4 class="font-display font-bold text-primary text-sm mb-4 uppercase tracking-wider">
          Learn
        </h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
          {learnLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-muted text-sm no-underline hover:text-accent transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Resources column */}
      <div>
        <h4 class="font-display font-bold text-primary text-sm mb-4 uppercase tracking-wider">
          Resources
        </h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-2.5">
          {resourceLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-muted text-sm no-underline hover:text-accent transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    {/* Bottom bar */}
    <div
      class="border-t border-border pt-6 flex flex-col sm:flex-row items-center justify-between gap-4"
    >
      <p class="text-muted text-xs">
        &copy; {currentYear} NoBro Bonds. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a
          href="/privacy"
          class="text-muted text-xs no-underline hover:text-accent transition-colors"
        >
          Privacy Policy
        </a>
        <a
          href="/terms"
          class="text-muted text-xs no-underline hover:text-accent transition-colors"
        >
          Terms of Use
        </a>
      </div>
    </div>
  </div>
</footer>
