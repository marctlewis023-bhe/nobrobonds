---
interface Props {
  attribution?: string;
}

const { attribution = "The NoBro Bonds Perspective" } = Astro.props;
---

<section class="bg-gradient-to-br from-primary to-primary/90 rounded-[20px] px-8 py-14 md:px-16 md:py-20 text-center my-16">
  <blockquote class="font-display font-bold text-white text-2xl md:text-3xl leading-snug max-w-3xl mx-auto m-0">
    <slot />
  </blockquote>
  <p class="text-white/60 text-sm mt-6">&mdash; {attribution}</p>
</section>
