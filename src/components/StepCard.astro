---
interface Props {
  title: string;
  time?: string;
}

const { title, time } = Astro.props;
---

<div class="bg-card rounded-[20px] p-7 border border-border">
  <div class="flex items-start justify-between gap-4 mb-3">
    <h3 class="font-display font-bold text-primary text-lg">{title}</h3>
    {time && (
      <span class="shrink-0 bg-lime/15 text-lime font-display font-bold text-xs px-3 py-1.5 rounded-full whitespace-nowrap">
        {time}
      </span>
    )}
  </div>
  <div class="text-muted text-[15px] leading-relaxed">
    <slot />
  </div>
</div>
