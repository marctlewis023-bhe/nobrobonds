---
export interface Props {
  items: { label: string; href?: string }[];
}
const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-muted mb-6">
  <ol class="flex flex-wrap items-center gap-1">
    <li>
      <a href="/" class="hover:text-accent no-underline">Home</a>
    </li>
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        <span class="text-border">/</span>
        {item.href ? (
          <a href={item.href} class="hover:text-accent no-underline">{item.label}</a>
        ) : (
          <span class="text-text font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
