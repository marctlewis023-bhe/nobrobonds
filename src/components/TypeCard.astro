---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
}

const { icon, title, description, href } = Astro.props;
---

<a
  href={href}
  class="group block bg-card rounded-[20px] p-7 border border-border no-underline transition-all duration-200 hover:-translate-y-1 hover:border-accent hover:shadow-lg"
>
  <div class="w-12 h-12 text-accent mb-4" set:html={icon} />
  <h4 class="font-display font-bold text-primary text-[17px] mb-2 group-hover:text-accent transition-colors">
    {title}
  </h4>
  <p class="text-muted text-sm leading-relaxed m-0">{description}</p>
</a>
