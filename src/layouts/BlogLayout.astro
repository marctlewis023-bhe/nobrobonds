---
import BaseLayout from "./BaseLayout.astro";
import SectionLabel from "../components/SectionLabel.astro";

interface Props {
  title: string;
  description: string;
  date: string;
  author: string;
  authorCredentials: string;
  category: string;
  keywords: string[];
  readingTime: string;
}

const {
  title,
  description,
  date,
  author,
  authorCredentials,
  category,
  keywords,
  readingTime,
} = Astro.props;

const siteUrl = "https://nobrobonds.com";
const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const breadcrumbs = [
  { name: "Home", href: "/" },
  { name: "Blog", href: "/blog" },
  { name: title, href: Astro.url.pathname },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  datePublished: date,
  author: {
    "@type": "Person",
    name: author,
  },
  publisher: {
    "@type": "Organization",
    name: "NoBro Bonds",
    url: siteUrl,
  },
  keywords: keywords.join(", "),
};
---

<BaseLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
  schema={articleSchema}
>
  <article class="max-w-[1280px] mx-auto px-6">
    {/* Breadcrumb */}
    <nav class="flex items-center gap-2 text-sm text-muted py-6" aria-label="Breadcrumb">
      {breadcrumbs.map((crumb, i) => (
        <>
          {i > 0 && <span class="text-border">/</span>}
          {i < breadcrumbs.length - 1 ? (
            <a href={crumb.href} class="text-muted hover:text-accent no-underline transition-colors">
              {crumb.name}
            </a>
          ) : (
            <span class="text-primary font-medium">{crumb.name}</span>
          )}
        </>
      ))}
    </nav>

    {/* Header */}
    <header class="max-w-3xl mb-10">
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-accent/10 text-accent font-display font-bold text-xs px-3 py-1.5 rounded-full uppercase tracking-wider">
          {category}
        </span>
        <span class="text-muted text-sm">{readingTime}</span>
      </div>

      <h1 class="font-display font-bold text-primary text-4xl md:text-5xl leading-tight mb-4">
        {title}
      </h1>

      <p class="text-muted text-xl leading-relaxed mb-6">{description}</p>

      {/* Author byline */}
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full bg-accent flex items-center justify-center text-white font-display font-bold text-sm shrink-0">
          NB
        </div>
        <div>
          <p class="text-primary font-medium text-sm">
            {author}
            {authorCredentials && (
              <span class="text-muted font-normal"> &middot; {authorCredentials}</span>
            )}
          </p>
          <p class="text-muted text-xs">{formattedDate}</p>
        </div>
      </div>
    </header>

    {/* Prose content */}
    <div class="max-w-3xl prose-nb mb-20">
      <slot />
    </div>

    {/* Related links */}
    <section class="max-w-3xl border-t border-border pt-10 pb-16">
      <SectionLabel>Keep Learning</SectionLabel>
      <h2 class="font-display font-bold text-primary text-xl mt-3 mb-6">
        Related Resources
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a
          href="/how-bonding-works"
          class="bg-card rounded-[16px] border border-border p-5 no-underline hover:border-accent hover:-translate-y-0.5 transition-all"
        >
          <p class="font-display font-bold text-primary text-sm mb-1">How Bonding Works</p>
          <p class="text-muted text-xs">The fundamentals explained</p>
        </a>
        <a
          href="/bond-types"
          class="bg-card rounded-[16px] border border-border p-5 no-underline hover:border-accent hover:-translate-y-0.5 transition-all"
        >
          <p class="font-display font-bold text-primary text-sm mb-1">Bond Types</p>
          <p class="text-muted text-xs">Find your specific bond</p>
        </a>
        <a
          href="/resources/cost-estimator"
          class="bg-card rounded-[16px] border border-border p-5 no-underline hover:border-accent hover:-translate-y-0.5 transition-all"
        >
          <p class="font-display font-bold text-primary text-sm mb-1">Cost Estimator</p>
          <p class="text-muted text-xs">Calculate your premium</p>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .prose-nb :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-nb :global(h3) {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--color-primary);
    font-size: 1.2rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose-nb :global(p) {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .prose-nb :global(ul),
  .prose-nb :global(ol) {
    color: var(--color-text);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }
  .prose-nb :global(li) {
    margin-bottom: 0.35rem;
  }
  .prose-nb :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-muted);
  }
  .prose-nb :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose-nb :global(a:hover) {
    color: var(--color-primary);
  }
  .prose-nb :global(strong) {
    font-weight: 700;
    color: var(--color-primary);
  }
</style>
