---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { glossary } from '../../data/glossary';

const sorted = [...glossary].sort((a, b) => a.term.localeCompare(b.term));

const grouped = sorted.reduce<Record<string, typeof sorted>>((acc, term) => {
  const letter = term.term[0].toUpperCase();
  if (!acc[letter]) acc[letter] = [];
  acc[letter].push(term);
  return acc;
}, {});

const letters = Object.keys(grouped).sort();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  name: 'Surety Bond Glossary',
  description: '30+ surety bond terms defined in plain English.',
  hasDefinedTerm: sorted.map((t) => ({
    '@type': 'DefinedTerm',
    name: t.term,
    description: t.definition,
  })),
};

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Resources', href: '/resources' },
  { name: 'Glossary', href: '/resources/glossary' },
];
---

<BaseLayout
  title="Surety Bond Glossary — 30+ Terms in Plain English"
  description="Complete surety bond glossary covering premiums, commissions, underwriting, indemnity agreements, and more. Every term defined in plain English."
  schema={schema}
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-[1280px] mx-auto px-6 py-12">
    <Breadcrumbs items={[{ label: 'Resources', href: '/resources' }, { label: 'Glossary' }]} />

    <div class="max-w-3xl mb-10">
      <SectionLabel>Reference</SectionLabel>
      <h1 class="font-display font-bold text-primary text-4xl md:text-5xl leading-tight mt-3 mb-4">
        Surety Bond Glossary
      </h1>
      <p class="text-muted text-lg leading-relaxed">
        {sorted.length} terms defined in plain English. No jargon walls, no email gates. Bookmark this page — it is the surety bond dictionary the industry does not want you to have.
      </p>
    </div>

    <!-- Letter Navigation -->
    <nav class="flex flex-wrap gap-2 mb-10" aria-label="Glossary letter navigation">
      {letters.map((letter) => (
        <a
          href={`#letter-${letter}`}
          class="w-10 h-10 rounded-[10px] bg-card border border-border flex items-center justify-center font-display font-bold text-sm text-primary hover:bg-accent hover:text-white hover:border-accent no-underline transition-colors"
        >
          {letter}
        </a>
      ))}
    </nav>

    <!-- Terms -->
    <div class="max-w-3xl space-y-12">
      {letters.map((letter) => (
        <section id={`letter-${letter}`}>
          <h2 class="font-display font-bold text-accent text-3xl mb-6 border-b-2 border-accent/20 pb-2">{letter}</h2>
          <div class="space-y-4">
            {grouped[letter].map((term) => (
              <div id={term.slug} class="bg-card rounded-[16px] border border-border p-6 scroll-mt-24">
                <h3 class="font-display font-bold text-primary text-lg mb-2">{term.term}</h3>
                <p class="text-text text-[15px] leading-relaxed">{term.definition}</p>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- Back to top -->
    <div class="text-center mt-12">
      <a href="#" class="text-accent text-sm no-underline hover:underline">Back to top &uarr;</a>
    </div>
  </div>
</BaseLayout>
